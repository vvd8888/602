<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Priority?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="10" style="-fx-padding: 20;"
      fx:controller="com.teach.javafx.controller.StudentSelectController">

    <Label text="请选择要查看的同学"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <!-- 搜索区域 -->
    <HBox spacing="10" style="-fx-padding: 0 0 10 0;">
        <TextField fx:id="searchField" promptText="输入学号或姓名搜索" prefWidth="300" />
        <Button fx:id="searchButton" text="搜索" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="viewMyInfoButton" text="查看我的信息"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
    </HBox>

    <!-- 同学列表表格 -->
    <TableView fx:id="studentTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="numCol" text="学号" prefWidth="120" />
            <TableColumn fx:id="nameCol" text="姓名" prefWidth="100" />
            <TableColumn fx:id="genderCol" text="性别" prefWidth="60" />
            <TableColumn fx:id="classNameCol" text="班级" prefWidth="100" />
            <TableColumn fx:id="phoneCol" text="电话" prefWidth="120" />
            <TableColumn fx:id="emailCol" text="邮箱" prefWidth="150" />
            <TableColumn fx:id="operationCol" text="操作" prefWidth="100" />
        </columns>
    </TableView>
</VBox>