<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teach.javafx.controller.TeacherOpenCourseController"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <!-- 标题栏 -->
    <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #2196F3;">
        <Label text="📚 老师开设课程" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- 统计信息 -->
    <HBox spacing="30" style="-fx-padding: 15; -fx-background-color: white; -fx-border-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <VBox spacing="5" alignment="CENTER">
            <Label text="总课程数" style="-fx-text-fill: #666; -fx-font-size: 12px;" />
            <Label fx:id="totalCoursesLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2196F3;" />
        </VBox>
        <VBox spacing="5" alignment="CENTER">
            <Label text="开放课程" style="-fx-text-fill: #666; -fx-font-size: 12px;" />
            <Label fx:id="openCoursesLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;" />
        </VBox>
        <VBox spacing="5" alignment="CENTER">
            <Label text="关闭课程" style="-fx-text-fill: #666; -fx-font-size: 12px;" />
            <Label fx:id="closedCoursesLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f44336;" />
        </VBox>
        <VBox spacing="5" alignment="CENTER">
            <Label text="总学生数" style="-fx-text-fill: #666; -fx-font-size: 12px;" />
            <Label fx:id="totalStudentsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FF9800;" />
        </VBox>
    </HBox>

    <!-- 工具栏 -->
    <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: white; -fx-border-radius: 5;">
        <Button text="➕ 开设新课" onAction="#onAddNewCourseClick"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" />
        <Button text="🔄 刷新" onAction="#onRefreshClick"
                style="-fx-padding: 8 15; -fx-background-color: #2196F3; -fx-text-fill: white;" />
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" promptText="搜索课程..."
                   style="-fx-pref-width: 200;" />
        <ComboBox fx:id="statusFilterCombo" promptText="状态筛选"
                  style="-fx-pref-width: 120;" />
        <Button text="搜索" onAction="#onSearchClick"
                style="-fx-padding: 8 15; -fx-background-color: #9C27B0; -fx-text-fill: white;" />
    </HBox>

    <!-- 课程表格 -->
    <TableView fx:id="coursesTable" style="-fx-background-color: white; -fx-border-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="numColumn" text="课程编号" prefWidth="100" />
            <TableColumn fx:id="nameColumn" text="课程名称" prefWidth="200" />
            <TableColumn fx:id="creditColumn" text="学分" prefWidth="80" />
            <TableColumn fx:id="teacherColumn" text="授课教师" prefWidth="120" />
            <TableColumn fx:id="timeColumn" text="上课时间" prefWidth="150" />
            <TableColumn fx:id="classroomColumn" text="上课地点" prefWidth="120" />
            <TableColumn fx:id="statusColumn" text="状态" prefWidth="100" />
            <TableColumn fx:id="studentCountColumn" text="学生数" prefWidth="80" />
            <TableColumn fx:id="operateColumn" text="操作" prefWidth="200" />
        </columns>
    </TableView>

</VBox>