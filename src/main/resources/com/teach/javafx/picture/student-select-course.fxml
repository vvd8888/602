<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teach.javafx.controller.StudentSelectCourseController"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #9C27B0;">
        <Label text="🎒 学生选课" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox spacing="30" style="-fx-padding: 15; -fx-background-color: white; -fx-border-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <VBox spacing="5" alignment="CENTER">
            <Label text="可选课程" style="-fx-text-fill: #666; -fx-font-size: 12px;" />
            <Label fx:id="availableCoursesLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #9C27B0;" />
        </VBox>
        <VBox spacing="5" alignment="CENTER">
            <Label text="已选课程" style="-fx-text-fill: #666; -fx-font-size: 12px;" />
            <Label fx:id="selectedCoursesLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2196F3;" />
        </VBox>
        <VBox spacing="5" alignment="CENTER">
            <Label text="总学分" style="-fx-text-fill: #666; -fx-font-size: 12px;" />
            <Label fx:id="totalCreditsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;" />
        </VBox>
    </HBox>

    <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: white; -fx-border-radius: 5;">
        <Label text="🕐 当前学期：" style="-fx-font-size: 14px;" />
        <Label fx:id="semesterLabel" text="2024-2025学年第一学期" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🔄 刷新" onAction="#onRefreshClick"
                style="-fx-padding: 8 15; -fx-background-color: #2196F3; -fx-text-fill: white;" />
    </HBox>

    <TableView fx:id="coursesTable" style="-fx-background-color: white; -fx-border-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="numColumn" text="课程编号" prefWidth="100" />
            <TableColumn fx:id="nameColumn" text="课程名称" prefWidth="200" />
            <TableColumn fx:id="creditColumn" text="学分" prefWidth="80" />
            <TableColumn fx:id="teacherColumn" text="授课教师" prefWidth="120" />
            <TableColumn fx:id="timeColumn" text="上课时间" prefWidth="150" />
            <TableColumn fx:id="classroomColumn" text="上课地点" prefWidth="120" />
            <TableColumn fx:id="statusColumn" text="状态" prefWidth="100" />
            <TableColumn fx:id="studentCountColumn" text="已选人数" prefWidth="80" />
            <TableColumn fx:id="capacityColumn" text="容量" prefWidth="80" />
            <TableColumn fx:id="operationColumn" text="操作" prefWidth="120" />
        </columns>
    </TableView>

</VBox>