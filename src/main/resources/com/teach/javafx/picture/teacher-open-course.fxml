<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teach.javafx.controller.TeacherOpenCourseController">

    <!-- 标题栏 -->
    <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #2196F3;">
        <Label text="我的课程管理" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="开设新课" onAction="#onAddNewCourseClick"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" />
    </HBox>

    <!-- 统计信息 -->
    <HBox spacing="20" style="-fx-padding: 10; -fx-background-color: #f5f5f5;">
        <Label fx:id="totalCoursesLabel" text="总课程数: 0" />
        <Label fx:id="openCountLabel" text="开放课程: 0" />
        <Label fx:id="closedCountLabel" text="关闭课程: 0" />
        <Label fx:id="pendingCountLabel" text="待审核: 0" />
    </HBox>

    <!-- 工具栏 -->
    <HBox spacing="10" style="-fx-padding: 10;">
        <Button text="刷新" onAction="#onRefreshClick" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- 我的课程表格 -->
    <Label text="我的课程列表" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10;" />
    <TableView fx:id="mySelectionsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="selectedNumColumn" text="课程编号" prefWidth="100" />
            <TableColumn fx:id="selectedNameColumn" text="课程名称" prefWidth="200" />
            <TableColumn fx:id="selectedCreditColumn" text="学分" prefWidth="80" />
            <TableColumn fx:id="teacherColumn" text="授课教师" prefWidth="120" />
            <TableColumn fx:id="timeColumn" text="上课时间" prefWidth="150" />
            <TableColumn fx:id="classroomColumn" text="上课地点" prefWidth="120" />
            <TableColumn fx:id="statusColumn" text="状态" prefWidth="100" />
            <TableColumn fx:id="operateColumn" text="操作" prefWidth="200" />
        </columns>
    </TableView>

</VBox>